FROM node:20-slim

# System deps: Python, psql client, curl
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        postgresql-client \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code@latest

# Create audit directories and auth staging area owned by node user
RUN mkdir -p /audit/input /audit/output /audit/auth && chown -R node:node /audit

# Copy the entrypoint
COPY --chown=node:node auditor/entrypoint.py /audit/entrypoint.py

# Run as non-root node user (planner + analyzer stages, no skip-permissions)
USER node
WORKDIR /audit
ENTRYPOINT ["python3", "/audit/entrypoint.py"]
